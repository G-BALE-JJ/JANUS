# 运行链路默认配置（control-link）
: "${GOLEM_CTRL_LINK_ENABLE:=1}"
: "${GOLEM_REQUEST_SCHEDULER_ENABLE:=1}"
: "${GOLEM_GROUP_MANAGER_ENABLE:=1}"
: "${GOLEM_WORKER_COMMAND_PROCESSOR_ENABLE:=1}"
: "${GOLEM_GROUP_MAX_GRANTS_PER_SCHEDULE:=1}"
: "${GOLEM_ARCH_SCRIPT:=architecture/ncores_selfcom_dma_ctrl.py}"
: "${GOLEM_MATMUL_DTYPE:=fp32}"

# 测速复跑开关。默认关闭，避免换矩阵维度时误复用旧 tensor/HBM/binary。
: "${GOLEM_SKIP_TENSOR_GEN:=0}"
: "${GOLEM_SKIP_HBM_GEN:=0}"
: "${GOLEM_SKIP_BUILD:=0}"

# 测速静默模式。默认关闭；打开后强制清掉继承环境里的大日志开关。
# 适合 wall-time 测试，避免 shell 里残留 GOLEM_DMA_TRACE=1 等导致日志膨胀。
: "${GOLEM_BENCH_QUIET_LOGS:=0}"
# 可选：测速时关闭 SST 全量统计。默认保留统计，避免影响 NoC/HBM 后处理。
: "${GOLEM_BENCH_DISABLE_SST_STATS:=0}"
if [[ "$GOLEM_BENCH_QUIET_LOGS" -ne 0 ]]; then
	GOLEM_ROCC_VERBOSE=0
	GOLEM_GM_VERBOSE=0
	GOLEM_GM_DUMP_DATA=0
	GOLEM_STAGE_PROGRESS=0
	GOLEM_RUNTIME_SILENT=1
	GOLEM_SILENT=1
	GOLEM_CTRL_VERBOSE=0
	GOLEM_REQUEST_SCHEDULER_VERBOSE=0
	GOLEM_WORKER_COMMAND_PROCESSOR_VERBOSE=0
	GOLEM_WCP_STAGE3_TRACE=0
	GOLEM_DMA_TRACE=0
	GOLEM_REQUEST_SCHEDULER_TRACE=0
	GOLEM_LLSC_TRACE=0
	GOLEM_MH_DEBUG=0
	GOLEM_MH_DEBUG_LEVEL=0
	VANADIS_VERBOSE=0
	VANADIS_OS_VERBOSE=0
	GOLEM_MVM_DUMP_ENABLE=0
	GOLEM_PROGRESS_HEARTBEAT=0
	GOLEM_EXPORT_NOC_HEATMAPS=0
fi
if [[ "$GOLEM_BENCH_DISABLE_SST_STATS" -ne 0 ]]; then
	GOLEM_SST_STAT_LOAD_LEVEL=0
	GOLEM_SST_ENABLE_ALL_STATS=0
fi

export GOLEM_CTRL_LINK_ENABLE
export GOLEM_REQUEST_SCHEDULER_ENABLE
export GOLEM_GROUP_MANAGER_ENABLE
export GOLEM_WORKER_COMMAND_PROCESSOR_ENABLE
export GOLEM_CTRL_OVERLAP_AB
export GOLEM_GROUP_MAX_GRANTS_PER_SCHEDULE
export GOLEM_ARCH_SCRIPT
export GOLEM_MATMUL_DTYPE
export GOLEM_SKIP_TENSOR_GEN
export GOLEM_SKIP_HBM_GEN
export GOLEM_SKIP_BUILD
export GOLEM_BENCH_QUIET_LOGS
export GOLEM_BENCH_DISABLE_SST_STATS
