# 网络/拓扑参数（用于 sweep）
: "${GOLEM_NUM_MEMORY_NODES:=5}"
: "${GOLEM_MEM_NODE_SIZE_BYTES:=134217728}"
# Identity window base默认与单个内存节点大小对齐（node0给OS，node1开始给数据）
: "${GOLEM_IDENTITY_BASE:=${GOLEM_MEM_NODE_SIZE_BYTES}}"

# Mesh 维度（Y 维由脚本按 core 数推导）
: "${GOLEM_MESH_DIM_X:=4}"

# NoC 路由器端口缓冲
: "${GOLEM_NOC_INPUT_BUF_SIZE:=512KB}"
: "${GOLEM_NOC_OUTPUT_BUF_SIZE:=512KB}"
: "${GOLEM_NOC_LINK_BW:=1200GB/s}"
: "${GOLEM_NOC_XBAR_BW:=1200GB/s}"
: "${GOLEM_NOC_FLIT_SIZE:=128B}"
: "${GOLEM_DIRCTRL_HIGHLINK_BW:=1200GB/s}"

# NoC 分区切分约束。默认允许 inter-router 与 router-local 边被 SST 分区器切分；
# core 内部小块的 no-cut 仍在 cpu_builder.py 中保留。
: "${GOLEM_NOC_INTER_ROUTER_NO_CUT:=0}"
: "${GOLEM_NOC_LOCAL_NO_CUT:=0}"

# GlobalMemory NetworkIF buffer_length（对应 --gm-buf）
: "${GOLEM_GM_BUFFER_LENGTH:=1024KB}"

export GOLEM_NUM_MEMORY_NODES
export GOLEM_MEM_NODE_SIZE_BYTES
export GOLEM_IDENTITY_BASE
export GOLEM_MESH_DIM_X
export GOLEM_NOC_INPUT_BUF_SIZE
export GOLEM_NOC_OUTPUT_BUF_SIZE
export GOLEM_NOC_LINK_BW
export GOLEM_NOC_XBAR_BW
export GOLEM_NOC_FLIT_SIZE
export GOLEM_DIRCTRL_HIGHLINK_BW
export GOLEM_NOC_INTER_ROUTER_NO_CUT
export GOLEM_NOC_LOCAL_NO_CUT
export GOLEM_GM_BUFFER_LENGTH
