: "${GOLEM_TOTAL_GROUPS:=4}"

: "${GOLEM_ARRAY_INPUT_SIZE:=64}"
: "${GOLEM_ARRAY_OUTPUT_SIZE:=64}"
: "${GOLEM_NUM_ARRAYS:=64}"

: "${GOLEM_TOTAL_CORES:=20}"
: "${GOLEM_TOTAL_GEMM_CORES:=20}"

: "${GOLEM_GEMM_M:=1024}"
: "${GOLEM_GEMM_N:=1024}"
: "${GOLEM_GEMM_K:=1024}"

: "${GOLEM_GEMM_BLOCK_M:=64}"
: "${GOLEM_GEMM_BLOCK_N:=64}"
: "${GOLEM_GEMM_BLOCK_K:=64}"

# 可选 bias（默认关闭）
: "${GOLEM_BIAS_ENABLE:=0}"
: "${GOLEM_BIAS_VALUE:=0}"

export GOLEM_TOTAL_GROUPS
export GOLEM_ARRAY_INPUT_SIZE
export GOLEM_ARRAY_OUTPUT_SIZE
export GOLEM_NUM_ARRAYS
export GOLEM_TOTAL_CORES
export GOLEM_TOTAL_GEMM_CORES
export GOLEM_GEMM_M
export GOLEM_GEMM_N
export GOLEM_GEMM_K
export GOLEM_GEMM_BLOCK_M
export GOLEM_GEMM_BLOCK_N
export GOLEM_GEMM_BLOCK_K
export GOLEM_BIAS_ENABLE
export GOLEM_BIAS_VALUE
