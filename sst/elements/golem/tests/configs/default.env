# Auto-loaded by run_noc_dma_pipeline.sh when present.
# This file is now a lightweight aggregator that sources categorized presets.
# Priority remains: CLI > env > these defaults.

CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 分类配置：按顺序加载，后者可覆盖前者。
# 10: core/gemm, 20: dma, 25: latency, 30: network, 40: debug/log, 50: tensor/verify, 60: run
# shellcheck source=/dev/null
source "$CONFIG_DIR/10_core_gemm.env"
# shellcheck source=/dev/null
source "$CONFIG_DIR/20_dma.env"
# shellcheck source=/dev/null
source "$CONFIG_DIR/25_latency.env"
# shellcheck source=/dev/null
source "$CONFIG_DIR/30_network.env"
# shellcheck source=/dev/null
source "$CONFIG_DIR/40_debug_io.env"
# shellcheck source=/dev/null
source "$CONFIG_DIR/50_tensor_verify.env"
# shellcheck source=/dev/null
source "$CONFIG_DIR/60_run.env"

# Frontend/runtime defaults (only set when not provided by caller env)
export LENET5_WEIGHT_SOURCE="${LENET5_WEIGHT_SOURCE:-onnx}"
export GOLEM_DMA_OVERLAP="${GOLEM_DMA_OVERLAP:-0}"
export GOLEM_CTRL_OVERLAP_AB="${GOLEM_CTRL_OVERLAP_AB:-1}"

export CONFIG_DIR
