# 输入与校验
# - synthetic: 使用 gen_hbm_init.py 内部模式
# - sample: 自动生成 data/a.bin + data/b.bin
# - file: 使用 GOLEM_TENSOR_A_FILE / GOLEM_TENSOR_B_FILE
: "${GOLEM_TENSOR_SOURCE:=sample}"
: "${GOLEM_TENSOR_DIR:=${PWD}/data}"

# 端到端 C=AxB 校验
: "${GOLEM_VERIFY_C:=1}"

export GOLEM_TENSOR_SOURCE
export GOLEM_TENSOR_DIR
export GOLEM_VERIFY_C
