# RoCC/MVM latency knobs
# mvm.gm2imat / mvm.gm2ivec / mvm.ovec2gm are cycle-based in RoCCAnalog.
: "${GOLEM_LATENCY_MVM_GM2IMAT:=10}"
: "${GOLEM_LATENCY_MVM_GM2IVEC:=10}"
: "${GOLEM_LATENCY_MVM_OVEC2GM:=10}"

# MVM compute latency model (cycles derived from CU parameters in cpu_builder.py)
: "${GOLEM_ARRAY_NUM_CU:=$GOLEM_ARRAY_OUTPUT_SIZE}"
: "${GOLEM_ARRAY_MAC_PER_CU_PER_CYCLE:=1}"
: "${GOLEM_ARRAY_PIPELINE_DEPTH:=2}"
: "${VANADIS_CPU_CLOCK:=1.0GHz}"
: "${GOLEM_ARRAY_CLOCK:=1.0GHz}"
: "${GOLEM_MEMCTRL_CLOCK:=1.0GHz}"

export GOLEM_LATENCY_MVM_GM2IMAT
export GOLEM_LATENCY_MVM_GM2IVEC
export GOLEM_LATENCY_MVM_OVEC2GM
export GOLEM_ARRAY_NUM_CU
export GOLEM_ARRAY_MAC_PER_CU_PER_CYCLE
export GOLEM_ARRAY_PIPELINE_DEPTH
export VANADIS_CPU_CLOCK
export GOLEM_ARRAY_CLOCK
export GOLEM_MEMCTRL_CLOCK
