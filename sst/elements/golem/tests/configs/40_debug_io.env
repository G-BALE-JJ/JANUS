
# 组件类型
: "${GOLEM_ROCC_TYPE:=golem.RoCCAnalogInt}"
: "${GOLEM_ARRAY_TYPE:=golem.MVMIntArray}"

# 日志与调试
: "${GOLEM_ROCC_VERBOSE:=0}"
: "${GOLEM_GM_VERBOSE:=0}"
: "${GOLEM_GM_DUMP_DATA:=0}"
: "${GOLEM_STAGE_PROGRESS:=0}"
: "${GOLEM_RUNTIME_SILENT:=1}"
: "${GOLEM_SILENT:=${GOLEM_RUNTIME_SILENT}}"
: "${GOLEM_CTRL_VERBOSE:=0}"
: "${GOLEM_REQUEST_SCHEDULER_VERBOSE:=0}"
: "${GOLEM_WORKER_COMMAND_PROCESSOR_VERBOSE:=0}"
: "${GOLEM_WCP_STAGE3_TRACE:=0}"
: "${GOLEM_DMA_TRACE:=0}"
: "${GOLEM_REQUEST_SCHEDULER_TRACE:=0}"
: "${GOLEM_LLSC_TRACE:=0}"
: "${GOLEM_MH_DEBUG:=0}"
: "${GOLEM_MH_DEBUG_LEVEL:=0}"
: "${VANADIS_VERBOSE:=0}"
: "${VANADIS_OS_VERBOSE:=${VANADIS_VERBOSE}}"

# SST 运行时参数与统计开关
# 默认单线程，避免多线程分区带来的同步开销影响常规实验。
# 多线程测速时可临时覆盖，例如：
#   GOLEM_SST_ARGS="--num-threads=4 --partitioner=linear"
: "${GOLEM_SST_ARGS:=--num-threads=1}"
# Router/NoC 统计默认开启；只有 GOLEM_BENCH_DISABLE_SST_STATS=1 时才会在 60_run.env 中关闭。
: "${GOLEM_SST_STAT_LOAD_LEVEL:=16}"
: "${GOLEM_SST_ENABLE_ALL_STATS:=1}"

# MVM dump
: "${GOLEM_MVM_DUMP_ENABLE:=0}"
: "${GOLEM_MVM_DUMP_MODE:=overwrite}"

# 轻量进度心跳（默认关闭，避免额外日志开销）
: "${GOLEM_PROGRESS_HEARTBEAT:=1}"
: "${GOLEM_PROGRESS_INTERVAL_CYCLES:=50000}"

# NoC heatmap 导出（默认关闭，避免额外后处理开销）
: "${GOLEM_EXPORT_NOC_HEATMAPS:=0}"

# 运行日志文件名（相对路径时放到 artifacts/logs）
: "${GOLEM_PRESET_LOG:=test_default.log}"

export GOLEM_ROCC_TYPE
export GOLEM_ARRAY_TYPE
export GOLEM_ROCC_VERBOSE
export GOLEM_GM_VERBOSE
export GOLEM_GM_DUMP_DATA
export GOLEM_STAGE_PROGRESS
export GOLEM_RUNTIME_SILENT
export GOLEM_SILENT
export GOLEM_CTRL_VERBOSE
export GOLEM_REQUEST_SCHEDULER_VERBOSE
export GOLEM_WORKER_COMMAND_PROCESSOR_VERBOSE
export GOLEM_WCP_STAGE3_TRACE
export GOLEM_DMA_TRACE
export GOLEM_REQUEST_SCHEDULER_TRACE
export GOLEM_LLSC_TRACE
export GOLEM_MH_DEBUG
export GOLEM_MH_DEBUG_LEVEL
export VANADIS_VERBOSE
export VANADIS_OS_VERBOSE
export GOLEM_SST_ARGS
export GOLEM_SST_STAT_LOAD_LEVEL
export GOLEM_SST_ENABLE_ALL_STATS
export GOLEM_MVM_DUMP_ENABLE
export GOLEM_MVM_DUMP_MODE
export GOLEM_PROGRESS_HEARTBEAT
export GOLEM_PROGRESS_INTERVAL_CYCLES
export GOLEM_EXPORT_NOC_HEATMAPS
export GOLEM_PRESET_LOG
